<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>최고 관리자 제어 콘솔</title>
    <style>
        /* 🎨 글로벌 레이아웃 테마 */
        body { font-family: 'Malgun Gothic', sans-serif; background-color: #f1f5f9; margin: 0; padding: 30px; color: #1e293b; }
        .container { max-width: 1400px; margin: 0 auto; }

        /* 👑 최상단 제어 콘솔 마스터 헤더 */
        .admin-header {
            background: white; padding: 20px 30px; border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border-left: 6px solid #1B434A;
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;
        }
        .admin-header h1 { margin: 0; font-size: 24px; color: #0f172a; display: flex; align-items: center; gap: 8px; }
        .btn-home {
            padding: 10px 20px; background-color: #1B434A; color: white; text-decoration: none;
            border-radius: 6px; font-weight: bold; font-size: 14px; transition: background 0.2s;
        }
        .btn-home:hover { background-color: #112F34; }

        /* 🗂️ 상단 2단 배치 폼 레이아웃 */
        .top-grid { display: flex; gap: 25px; margin-bottom: 25px; }
        .form-card {
            flex: 1; background: white; border-radius: 12px; padding: 25px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0;
        }
        .form-card h2 {
            margin-top: 0; margin-bottom: 20px; font-size: 18px; color: #0f172a;
            border-left: 4px solid #1B434A; padding-left: 10px;
        }

        /* 폼 요소 공통 스타일 */
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; font-weight: bold; margin-bottom: 6px; font-size: 13px; color: #475569; }
        .form-group input, .form-group textarea {
            width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;
            box-sizing: border-box; font-size: 14px; background-color: #f8fafc; outline: none; transition: border 0.2s;
        }
        .form-group input:focus, .form-group textarea:focus { border-color: #1B434A; background-color: #fff; }

        /* 등록 및 배포 통합 마스터 버튼 */
        .btn-submit {
            width: 100%; padding: 12px; background-color: #1B434A; color: white; border: none;
            border-radius: 6px; font-size: 14px; font-weight: bold; cursor: pointer;
            transition: background 0.2s; display: flex; justify-content: center; align-items: center; gap: 6px;
        }
        .btn-submit:hover { background-color: #112F34; }

        /* 📊 하단 데이터 관제 시스템 카드 */
        .data-card {
            background: white; border-radius: 12px; padding: 25px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; margin-bottom: 25px;
        }
        .data-card h2 {
            margin-top: 0; font-size: 18px; color: #0f172a; margin-bottom: 20px;
            border-left: 4px solid #1B434A; padding-left: 10px;
        }

        /* 고급 플랫 테이블 스타일 스키마 */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: center; font-size: 14px; min-width: 800px; }
        th { background-color: #f8fafc; color: #475569; padding: 14px 10px; border-bottom: 2px solid #e2e8f0; font-weight: bold; }
        td { padding: 14px 10px; border-bottom: 1px solid #e2e8f0; color: #334155; vertical-align: middle; }
        tr:hover { background-color: #f8fafc; }

        .price-highlight { color: #e11d48; font-weight: bold; }

        /* 테이블 제어 셀렉트 박스 및 배송 전송 버튼 */
        .select-control { padding: 6px 10px; border-radius: 4px; border: 1px solid #cbd5e1; font-size: 13px; outline: none; }
        .select-control:focus { border-color: #1B434A; }
        .btn-table-action {
            padding: 6px 14px; background-color: #1B434A; color: white; border: none;
            border-radius: 4px; font-weight: bold; font-size: 12px; cursor: pointer; transition: background 0.2s;
        }
        .btn-table-action:hover { background-color: #112F34; }
        .btn-delete { background-color: #ef4444; }
        .btn-delete:hover { background-color: #dc2626; }
    </style>
</head>
<body>

<div class="container">

    <!-- 👑 콘솔 대시보드 헤더 메인 -->
    <header class="admin-header">
        <h1>👑 쇼핑몰 최고 관리자 제어 콘솔</h1>
        <a href="/" class="btn-home">🏠 사용자 메인 홈 이동</a>
    </header>

    <div class="top-grid">
        <!-- ➕ 1. 신규 쇼핑몰 상품 등록 폼 구역 -->
        <section class="form-card">
            <h2>+ 쇼핑몰 신규 보충제 상품 추가</h2>
            <form action="/admin/product/add" method="POST">
                <div class="form-group">
                    <label>보충제/상품 이름:</label>
                    <input type="text" name="name" placeholder="예: 헬스 트레이너용 프로틴 고단백 355ml x 24개" required>
                </div>
                <div class="form-group">
                    <label>판매 가격 (원):</label>
                    <input type="number" name="price" placeholder="예: 38000" required>
                </div>
                <div class="form-group">
                    <label>대표 식별 이모지 (Emoji):</label>
                    <input type="text" name="emoji" placeholder="예: 🥤">
                </div>
                <div class="form-group">
                    <label>상품 상세 설명 글:</label>
                    <input type="text" name="description" placeholder="제품 고유의 특장점과 단백질 성분 및 프로필을 기술하세요.">
                </div>
                <div class="form-group">
                    <label>매핑 이미지 파일명 (public/images 내 배치):</label>
                    <input type="text" name="image" placeholder="protein.png (미입력 시 default.jpg)">
                </div>
                <button type="submit" class="btn-submit">📦 신규 상품 등록</button>
            </form>
        </section>

        <!-- 📢 2. 메인 전역 공지사항 배포 폼 구역 -->
        <section class="form-card">
            <h2>📢 메인 표출용 전용 공지사항 작성</h2>
            <form action="/admin/notice/add" method="POST">
                <div class="form-group">
                    <label>공지사항 핵심 제목:</label>
                    <input type="text" name="title" placeholder="[안내] 서버 정기 점검 및 배송 휴무 안내" required>
                </div>
                <div class="form-group">
                    <label>공지 세부 내용:</label>
                    <textarea name="content" rows="7" placeholder="쇼핑몰 메인 피드에 노출할 공지사항 상세 내용을 입력하세요." required></textarea>
                </div>
                <button type="submit" class="btn-submit">📢 메인 전역 공지사항 배포</button>
            </form>
        </section>
    </div>

    <!-- 🚚 3. 실시간 주문 현황 배송 관제 시스템 테이블 -->
    <section class="data-card">
        <h2>🚚 고객 실시간 주문 현황 배송 관제</h2>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>주문 고유번호</th>
                        <th>주문 유저 ID</th>
                        <th>수령인 성명</th>
                        <th>배송 주소지</th>
                        <th>결제 총액</th>
                        <th>현재 배송 상태 설정</th>
                        <th>트래킹 제어</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orders && orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td style="font-weight: bold;">#<%= order.id %></td>
                                <td><%= order.user_id || '비회원' %></td>
                                <td><%= order.receiver_name %></td>
                                <td style="text-align: left;"><%= order.delivery_address %></td>
                                <td class="price-highlight">₩<%= order.total_price.toLocaleString() %></td>
                                <form action="/admin/order/status" method="POST">
                                    <input type="hidden" name="order_id" value="<%= order.id %>">
                                    <td>
                                        <select name="status" class="select-control">
                                            <option value="결제완료" <%= order.status === '결제완료' ? 'selected' : '' %>>결제완료</option>
                                            <option value="배송중" <%= order.status === '배송중' ? 'selected' : '' %>>배송중</option>
                                            <option value="배송완료" <%= order.status === '배송완료' ? 'selected' : '' %>>배송완료</option>
                                            <option value="주문취소" <%= order.status === '주문취소' ? 'selected' : '' %>>주문취소</option>
                                        </select>
                                    </td>
                                    <td>
                                        <button type="submit" class="btn-table-action">🚚 전송</button>
                                    </td>
                                </form>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="7" style="color: #64748b; padding: 30px 0;">현재 인입된 주문 트랜잭션 내역이 없습니다.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>

    <!-- 👤 4. 전역 회원 권한 제어 모듈 테이블 추가 -->
    <section class="data-card">
        <h2>👥 전역 서비스 이용 회원 권한 제어 모듈</h2>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>회원 고유번호</th>
                        <th>로그인 아이디</th>
                        <th>회원명</th>
                        <th>계정 등급 권한</th>
                        <th>계정 활성화 상태</th>
                        <th>권한 변경 저장</th>
                        <th>물리 삭제</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users && users.length > 0) { %>
                        <% users.forEach(u => { %>
                            <tr>
                                <td><%= u.id %></td>
                                <td style="font-weight: bold;"><%= u.username %></td>
                                <td><%= u.name %></td>
                                <form action="/admin/user/update" method="POST">
                                    <input type="hidden" name="username" value="<%= u.username %>">
                                    <td>
                                        <select name="role" class="select-control">
                                            <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>일반 유저 (user)</option>
                                            <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>최고 관리자 (admin)</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select name="status" class="select-control">
                                            <option value="active" <%= u.status === 'active' ? 'selected' : '' %>>정상 활성 (active)</option>
                                            <option value="suspended" <%= u.status === 'suspended' ? 'selected' : '' %>>이용 정지 (suspended)</option>
                                        </select>
                                    </td>
                                    <td>
                                        <button type="submit" class="btn-table-action">💾 변경</button>
                                    </td>
                                </form>
                                <td>
                                    <form action="/admin/user/delete" method="POST" onsubmit="return confirm('이 회원 데이터를 영구 삭제하시겠습니까?');">
                                        <input type="hidden" name="username" value="<%= u.username %>">
                                        <button type="submit" class="btn-action btn-table-action btn-delete">🗑️ 삭제</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="7" style="color: #64748b; padding: 30px 0;">가입된 회원 데이터가 존재하지 않습니다.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>

</div>

</body>
</html>