<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title><%= post ? '글 수정' : (parentId ? '답글 작성' : '새 글 작성') %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 40px;
    }
    input[type="text"], textarea {
      width: 100%;
      margin-bottom: 15px;
      padding: 8px;
      font-size: 1em;
    }
    button {
      padding: 8px 16px;
      font-size: 1em;
    }
  </style>
</head>
<body>

  <h2><%= post ? '글 수정' : (parentId ? '답글 작성' : '새 글 작성') %></h2>

  <!-- 🌟 [교정 1]: 글 수정 또는 새 글 작성/답글 등록 시 404 라우팅 에러를 방지하기 위해 /stud7 경로 주입 -->
  <form action="<%= post ? '/stud7/board/edit/' + post.id : '/stud7/board/new' %>" method="post" enctype="multipart/form-data">
    <input type="hidden" name="parent_id" value="<%= post ? post.parent_id : parentId %>">

    <label for="title">제목</label><br>
    <input type="text" id="title" name="title" placeholder="제목" value="<%= post?.title || '' %>" required><br>

    <label for="content">내용</label><br>
    <textarea id="content" name="content" placeholder="내용" rows="8"><%= post?.content || '' %></textarea><br>
    <input type="file" name="attachment"><br><br>
    <button type="submit">저장</button>
  </form>

  <!-- 🌟 [교정 2]: 하위 라우트(board/new 등) 주소 상태에서 목록 복귀 시 경로가 중첩되어 꼬이지 않도록 절대 고정 경로 처리 -->
  <p><a href="/stud7/board">← 게시판으로 돌아가기</a></p>

</body>
</html>