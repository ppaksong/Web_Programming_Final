<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>장바구니</title>
    <link rel="stylesheet" href="./stylesheets/style.css">
    <style>
        body { font-family: 'Noto Sans KR', sans-serif; background-color: #f8f9fa; margin: 0; padding: 20px; }
        .cart-container { max-width: 800px; margin: 0 auto; background: #white; background-color: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #eee; padding: 15px; text-align: center; }
        th { background: #fcfcfc; font-weight: bold; }
        .total-box { background: #fff9db; border: 1px solid #ffe3e3; padding: 20px; text-align: right; border-radius: 8px; font-size: 1.3em; font-weight: bold; margin-bottom: 30px; }
        .checkout-section { background: #fdf2e9; border: 1px solid #fbd5b5; padding: 25px; border-radius: 8px; }
        .checkout-section h3 { margin-top: 0; color: #d9480f; border-bottom: 1px solid #fbd5b5; padding-bottom: 8px; }
        .form-row { display: flex; align-items: center; margin-bottom: 15px; }
        .form-row label { width: 120px; font-weight: bold; color: #495057; }
        .form-row input { flex: 1; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 1em; }
        .btn-order { background: #e67e22; color: white; border: none; padding: 12px 30px; font-size: 1.1em; font-weight: bold; border-radius: 6px; cursor: pointer; width: 100%; transition: background 0.2s; }
        .btn-order:hover { background: #d35400; }

        /* 🌟 상단 헤더 및 홈 버튼 스타일 추가 */
        .header-wrap { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ffcc00; padding-bottom: 10px; margin-bottom: 20px; }
        .header-wrap h1 { margin: 0; border: none; padding: 0; }
        .btn-home { background: #e9ecef; color: #495057; text-decoration: none; padding: 8px 16px; border-radius: 6px; font-weight: bold; border: 1px solid #ced4da; transition: 0.2s; }
        .btn-home:hover { background: #dee2e6; }
    </style>
</head>
<body>

    <div class="cart-container">
        <div class="header-wrap">
            <h1>🛒 내 장바구니 리스트</h1>
            <a href="./" class="btn-home">🏠 홈으로 가기</a>
        </div>

        <% if (cartItems && cartItems.length > 0) { %>
            <table>
                <thead>
                    <tr>
                        <th>상품명</th>
                        <th>단가</th>
                        <th>주문 수량</th>
                        <th>총액</th>
                    </tr>
                </thead>
                <tbody>
                    <% let total = 0; %>
                    <% cartItems.forEach(item => { %>
                        <% total += (item.price * item.quantity); %>
                        <tr>
                            <td><strong><%= item.name %></strong></td>
                            <td><%= item.price.toLocaleString() %>원</td>
                            <td><%= item.quantity %>개</td>
                            <td style="color: #e67e22; font-weight: bold;"><%= (item.price * item.quantity).toLocaleString() %>원</td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>

            <div class="total-box">
                최종 주문 합계 금액 : <span style="color: #e67e22;"><%= total.toLocaleString() %>원</span>
            </div>

            <div class="checkout-section">
                <h3>🚚 신속 배송 및 수령 정보 입력</h3>
                <form action="/order/confirm" method="POST">
                    <div class="form-row">
                        <label>받으실 분</label>
                        <input type="text" name="receiver_name" placeholder="홍길동" required>
                    </div>
                    <div class="form-row">
                        <label>연락처(HP)</label>
                        <input type="text" name="receiver_phone" placeholder="010-1234-5678" required>
                    </div>
                    <div class="form-row">
                        <label>배송 주소지</label>
                        <input type="text" name="delivery_address" placeholder="물품을 수령할 정확한 배송 주소" required>
                    </div>
                    <style>
                        .form-row input::placeholder { color: #adb5bd; font-size: 0.9em; }
                    </style>
                    <div style="margin-top: 20px;">
                        <button type="submit" class="btn-order">💳 안전하게 결제 및 주문 최종 확정</button>
                    </div>
                </form>
            </div>

        <% } else { %>
            <div style="text-align: center; padding: 50px 0; color: #868e96;">
                <p style="font-size: 3em; margin: 0;">🛒</p>
                <p style="font-size: 1.2em; margin: 15px 0;">장바구니에 담긴 상품이 없습니다.</p>
                <a href="./products" style="display: inline-block; background: #e67e22; color: #fff; padding: 10px 20px; text-decoration: none; border-radius: 4px; font-weight: bold;">과일 구경하러 가기</a>
            </div>
        <% } %>
    </div>

</body>
</html>