<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>전체 상품 목록 - PNU PROTEIN & HEALTHCARE</title>
  <!-- 🌟 [교정 1]: 하위 경로에서도 스타일시트가 깨지지 않도록 절대 고정 경로 처리 -->
  <link rel="stylesheet" href="/stud7/stylesheets/style.css">
  <style>
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 20px; }
    .product-card { border: 1px solid #ddd; border-radius: 10px; padding: 15px; text-align: center; background: #fff; transition: transform 0.2s; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
    .product-card img { width: 100%; max-height: 140px; object-fit: cover; border-radius: 8px; }
    .btn-group { display: flex; gap: 5px; margin-top: 15px; }

    /* 브랜드 아이덴티티 통일을 위해 메인 버튼 색상을 다크 틸 계열(#1B434A)로 변경 */
    .cart-button { padding: 8px 12px; background-color: #1B434A; color: #fff; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; flex: 2; font-size: 0.9em; width: 100%; transition: background 0.2s; }
    .cart-button:hover { background-color: #112F34; }

    .wish-button { padding: 8px 12px; background-color: #f1f5f9; color: #e11d48; border: 1px solid #cbd5e1; border-radius: 5px; cursor: pointer; font-weight: bold; flex: 1; font-size: 0.9em; }
    .wish-button:hover { background-color: #e2e8f0; }
  </style>
</head>
<body>

  <!-- 상단 네비게이션 헤더 바 -->
  <div style="background-color: #1B434A; color: white; padding: 20px; text-align: center;">
    <h2><span>💪</span> PNU PROTEIN & HEALTHCARE <span>💪</span></h2>
    <div style="margin-top: 15px;">
        <!-- 🌟 [교정 2]: 네비게이션 메뉴 링크들이 세션/라우트에 의해 갇히지 않도록 /stud7 고정 절대 경로 매핑 -->
        <a href="/stud7/" style="color: white; text-decoration: none; margin: 0 10px;">홈</a> |
        <a href="/stud7/products" style="color: white; text-decoration: none; margin: 0 10px;">상품목록</a> |
        <a href="/stud7/cart" style="color: white; text-decoration: none; margin: 0 10px;">장바구니</a> |
        <a href="/stud7/board" style="color: white; text-decoration: none; margin: 0 10px;">고객센터</a> |

        <% if (locals.user && locals.user.username) { %>
            <a href="/stud7/mypage" style="color: #60a5fa; text-decoration: none; margin: 0 10px; font-weight: bold;">마이페이지</a> |
            <a href="/stud7/user/logout" style="color: #f87171; text-decoration: none; margin: 0 10px; font-weight: bold;">로그아웃</a>
        <% } else { %>
            <a href="/stud7/user/login" style="color: white; text-decoration: none; margin: 0 10px;">로그인</a>
        <% } %>
    </div>
  </div>

  <main style="padding: 20px; max-width: 1200px; margin: 0 auto;">
    <header style="margin-bottom: 20px;">
      <h1 style="border-left: 5px solid #1B434A; padding-left: 10px; color: #1e293b;">🧾 전체 상품 라인업</h1>
      <p style="color: #64748b; font-size: 0.95em;">쇼핑몰의 모든 보조제 상품 목록입니다.</p>
    </header>

    <div class="product-grid">
      <% if (products && products.length > 0) { %>
        <% products.forEach(p => { %>
          <div class="product-card">

            <!-- 🌟 [교정 3]: 이미지 및 상품 이름 클릭 시 상세보기 이동 주소 보정 -->
            <a href="/stud7/products/<%= p.id %>">
              <!-- 🌟 [교정 4]: 정적 파일 이미지 경로 절대 주소 처리 -->
              <img src="/stud7/images/<%= p.image || 'default.jpg' %>" alt="<%= p.name %>">
            </a>

            <h3 style="font-size: 1.1em; margin: 12px 0 5px 0;">
              <a href="/stud7/products/<%= p.id %>" style="color: #333; text-decoration: none; font-weight: bold;">
                <%= p.emoji || '🧃' %> <%= p.name %>
              </a>
            </h3>

            <p style="font-size: 0.88em; color: #64748b; margin: 0 0 12px 0; height: 38px; overflow: hidden; line-height: 1.4;"><%= p.description %></p>
            <strong style="color: #e11d48; font-size: 1.15em;">₩<%= p.price.toLocaleString() %></strong>

            <div class="btn-group">
              <!-- 🛒 [교정 5]: 장바구니 담기 라우터 요청 주소 보정 -->
              <form action="/stud7/cart/add" method="POST" style="flex: 2; margin: 0; padding: 0;">
                <input type="hidden" name="product_id" value="<%= p.id %>">
                <button type="submit" class="cart-button">🛒 담기</button>
              </form>

              <!-- ❤️ [교정 6]: 위시리스트 찜하기 라우터 요청 주소 보정 -->
              <form action="/stud7/mypage/wish/add" method="POST" style="flex: 1; margin: 0; padding: 0;">
                <input type="hidden" name="product_id" value="<%= p.id %>">
                <button type="submit" class="wish-button">❤️ 찜</button>
              </form>
            </div>

          </div>
        <% }) %>
      <% } else { %>
        <p style="grid-column: 1/-1; text-align: center; color: #94a3b8; padding: 40px 0;">등록된 상품이 없습니다.</p>
      <% } %>
    </div>
  </main>

  <!-- 🌟 [교정 7]: 요청하신 대로 푸터의 브랜드명을 쇼핑몰 이름으로 전면 교정 완료 -->
  <footer style="text-align: center; padding: 30px; color: #94a3b8; margin-top: 50px; border-top: 1px solid #e2e8f0;">
    <p>&copy; 2026 PNU PROTEIN & HEALTHCARE. All rights reserved.</p>
  </footer>

</body>
</html>