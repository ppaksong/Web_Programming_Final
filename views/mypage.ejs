<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>마이페이지 허브</title>
    <style>
        /* 🎨 원래 디자인 완벽 유지 CSS */
        body { font-family: 'Malgun Gothic', sans-serif; background-color: #f8f9fa; margin: 0; padding: 30px; color: #333; }
        .container { max-width: 1100px; margin: 0 auto; }

        /* 헤더 및 홈버튼 */
        .header-area { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #1B434A; padding-bottom: 12px; margin-bottom: 25px; }
        .header-area h1 { margin: 0; font-size: 28px; color: #212529; }
        .home-btn { padding: 8px 16px; background-color: #eee; border: 1px solid #ccc; color: #333; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 14px; }
        .home-btn:hover { background-color: #ddd; }

        /* 2단 회원정보 레이아웃 */
        .info-grid { display: flex; gap: 20px; margin-bottom: 25px; }
        .card { flex: 1; background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .card h2 { margin-top: 0; margin-bottom: 20px; font-size: 18px; padding-bottom: 8px; }
        .card h2.text-red { color: #ff5252; border-bottom: 1px solid #ffebee; }
        .card h2.text-blue { color: #1B434A; border-bottom: 1px solid #e8f0fe; } /* 브랜드 메인 컬러 적용 */

        .info-text p { margin: 12px 0; font-size: 15px; line-height: 1.6; }
        .info-text strong { color: #555; }

        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; font-weight: bold; margin-bottom: 6px; font-size: 14px; color: #495057; }
        .form-group input { width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; box-sizing: border-box; font-size: 14px; }

        .btn-block { width: 100%; padding: 12px; background-color: #1B434A; color: white; border: none; border-radius: 4px; font-size: 14px; font-weight: bold; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 5px; transition: background 0.2s; } /* 브랜드 메인 컬러 적용 */
        .btn-block:hover { background-color: #112F34; }

        /* 주문 내역 테이블 디자인 */
        .wide-card { background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); margin-bottom: 25px; }
        .wide-card h2 { margin-top: 0; font-size: 18px; color: #2ecc71; margin-bottom: 20px; }
        .wide-card h2.text-heart { color: #ff4757; }

        table { width: 100%; border-collapse: collapse; text-align: center; font-size: 14px; }
        th { background-color: #f1f3f5; color: #495057; padding: 12px; border: 1px solid #dee2e6; font-weight: bold; }
        td { padding: 12px; border: 1px solid #dee2e6; color: #333; vertical-align: middle; }

        .order-id { font-weight: bold; color: #212529; }
        .price-text { color: #ff4d4d; font-weight: bold; }

        /* 상태 뱃지 및 제어 버튼 디자인 */
        .status-badge { background-color: #e8f5e9; color: #2e7d32; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; border: 1px solid #c8e6c9; }
        .status-badge.canceled { background-color: #ffebee; color: #c62828; border: 1px solid #ffcdd2; }
        .status-badge.returned { background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; }

        .inline-form { display: inline; margin: 0; padding: 0; }
        .btn-action { padding: 5px 10px; border: none; border-radius: 4px; font-weight: bold; font-size: 12px; cursor: pointer; color: white; }
        .btn-cancel { background-color: #ee5253; }
        .btn-cancel:hover { background-color: #ff3838; }
        .btn-return { background-color: #f1c40f; color: #333; }
        .btn-return:hover { background-color: #f39c12; }
    </style>
</head>
<body>

<div class="container">

    <div class="header-area">
        <h1>👤 마이페이지 허브</h1>
        <!-- 🌟 [교정 1]: 하위 경로 탈출 및 메인 홈 이동을 위한 절대 주소 수정 -->
        <a href="/stud7/" class="home-btn">🏠 홈으로 가기</a>
    </div>

    <!-- 👑 최고 권한 관리자 대시보드 게이트웨이 배너 추가 -->
    <% if (locals.user && user.role === 'admin') { %>
        <div class="wide-card" style="border: 2px dashed #1B434A; background-color: #f0f7f8; padding: 20px; margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; border-radius: 8px;">
            <div>
                <h3 style="margin: 0 0 5px 0; color: #1B434A; font-size: 18px;">👑 최고 권한 마스터 계정 안내</h3>
                <p style="margin: 0; color: #556b6f; font-size: 13px;">현재 로그인된 계정은 최고 관리자 권한을 가집니다. 상품 추가, 회원 상태 변경, 배송 상태 관리 전용 대시보드를 이용할 수 있습니다.</p>
            </div>
            <!-- 🌟 [교정 2]: 관리자 대시보드 진입 경로 보정 -->
            <a href="/stud7/admin" style="padding: 12px 24px; background-color: #1B434A; color: white; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 14px; box-shadow: 0 4px 6px rgba(27,67,74,0.15); transition: background 0.2s;">
                📊 관리자 마스터 대시보드 진입하기 →
            </a>
        </div>
    <% } %>

    <div class="info-grid">
        <div class="card">
            <h2 class="text-red">회원 정보</h2>
            <div class="info-text">
                <p><strong>아이디:</strong> <%= userInfo.username %></p>
                <p><strong>이름:</strong> <%= userInfo.name %></p>
                <p><strong>전화번호:</strong> <%= userInfo.phone %></p>
                <p><strong>배송지:</strong> <%= userInfo.address %></p>
            </div>
        </div>

        <div class="card">
            <h2 class="text-blue">내 정보 변경</h2>
            <!-- 🌟 [교정 3]: 회원 정보 업데이트 요청 경로 보정 -->
            <form action="/stud7/mypage/update" method="POST">
                <div class="form-group">
                    <label>비밀번호 변경</label>
                    <input type="password" name="password" placeholder="새로운 비밀번호 입력">
                </div>
                <div class="form-group">
                    <label>전화번호</label>
                    <input type="text" name="phone" value="<%= userInfo.phone %>" required>
                </div>
                <div class="form-group">
                    <label>기본 배송지 주소</label>
                    <input type="text" name="address" value="<%= userInfo.address %>" required>
                </div>
                <button type="submit" class="btn-block">💾 설정 저장 및 변경</button>
            </form>
        </div>
    </div>

    <!-- ⚙️ 관리자 전용 권한: 새 공지사항 작성 섹션 -->
    <% if (locals.user && user.role === 'admin') { %>
        <div class="wide-card" style="border: 1px solid #1B434A; border-top: 5px solid #1B434A;">
            <h2 style="color: #1B434A; margin-bottom: 5px; display: flex; align-items: center; gap: 8px;">⚙️ 관리자 권한: 새 공지사항 작성</h2>
            <p style="color: #64748b; font-size: 13px; margin-top: 0; margin-bottom: 20px;">이 영역은 관리자 계정으로 로그인 시에만 활성화됩니다. 등록된 소식은 메인 홈 상단에 즉시 게시됩니다.</p>

            <!-- 🌟 [교정 4]: 관리자 공지사항 등록 요청 액션 경로 보정 -->
            <form action="/stud7/admin/notice/add" method="POST">
                <div class="form-group">
                    <label style="font-weight: bold; color: #333;">공지사항 제목</label>
                    <input type="text" name="title" placeholder="홈페이지 메인에 노출될 공지 제목을 입력하세요" required>
                </div>
                <div class="form-group">
                    <label style="font-weight: bold; color: #333;">공지 상세 내용</label>
                    <textarea name="content" rows="4" placeholder="공지사항 세부 내용을 상세히 입력하세요" required
                              style="width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; box-sizing: border-box; font-size: 14px; font-family: inherit; resize: vertical;"></textarea>
                </div>
                <div style="text-align: right; margin-top: 15px;">
                    <button type="submit" style="padding: 10px 24px; background-color: #1B434A; color: white; border: none; border-radius: 4px; font-weight: bold; font-size: 14px; cursor: pointer; transition: background 0.2s;">
                        📢 공지사항 등록하기
                    </button>
                </div>
            </form>
        </div>
    <% } %>

    <div class="wide-card">
        <h2 style="color: #2ecc71;">📦 최근 주문 내역</h2>
        <% if (orders.length === 0) { %>
            <p style="text-align: center; color: #888; padding: 20px 0;">아직 쇼핑몰에서 주문하신 내역이 존재하지 않습니다.</p>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>주문번호</th>
                        <th>총 결제 금액</th>
                        <th>주문 상태</th>
                        <th>수령인</th>
                        <th>배송 연락처</th>
                        <th>배송 주소</th>
                        <th>주문 일시</th>
                        <th>주문 제어</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td class="order-id">#<%= order.id %></td>
                            <td class="price-text"><%= order.total_price.toLocaleString() %>원</td>

                            <td>
                                <span class="status-badge
                                    <%= (order.status==='주문취소') ? 'canceled' : '' %>
                                    <%= (order.status==='반품신청') ? 'returned' : '' %>">
                                    <%= order.status %>
                                </span>
                            </td>

                            <td><%= order.receiver_name %></td>
                            <td><%= order.receiver_phone %></td>
                            <td><%= order.delivery_address %></td>
                            <td style="color: #888;"><%= order.created_at || '최근 주문 건' %></td>

                            <td>
                                <% if (order.status === '결제완료') { %>
                                    <!-- 🌟 [교정 5]: 주문 취소 처리 액션 경로 보정 -->
                                    <form action="/stud7/mypage/order/cancel" method="POST" class="inline-form" onsubmit="return confirm('정말 이 주문을 취소하시겠습니까?');">
                                        <input type="hidden" name="order_id" value="<%= order.id %>">
                                        <button type="submit" class="btn-action btn-cancel">주문취소</button>
                                    </form>
                                <% } else if (order.status === '배송완료') { %>
                                    <!-- 🌟 [교정 6]: 반품 신청 처리 액션 경로 보정 -->
                                    <form action="/stud7/mypage/order/return" method="POST" class="inline-form" onsubmit="return confirm('이 주문에 대해 반품을 신청하시겠습니까?');">
                                        <input type="hidden" name="order_id" value="<%= order.id %>">
                                        <button type="submit" class="btn-action btn-return">반품신청</button>
                                    </form>
                                <% } else { %>
                                    <span style="color: #bbb; font-size: 12px;">변경불가</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>

    <% if (typeof wishItems !== 'undefined' && wishItems.length > 0) { %>
        <div class="wide-card">
            <h2 class="text-heart">❤️ 내가 찜한 관심 상품</h2>
            <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                <% wishItems.forEach(item => { %>
                    <div style="border: 1px solid #eee; padding: 15px; border-radius: 6px; background: #fff; width: 180px; text-align: center;">
                        <strong><%= item.name %></strong><br>
                        <span style="color: #ff4d4d; font-size: 13px;"><%= item.price.toLocaleString() %>원</span>

                        <!-- 🌟 [교정 7]: 관심 상품 위시리스트 삭제 요청 경로 보정 -->
                        <form action="/stud7/mypage/wish/delete" method="POST" style="margin-top: 10px;">
                            <input type="hidden" name="wish_id" value="<%= item.wish_id %>">
                            <button type="submit" style="padding: 3px 8px; font-size: 11px; background: #ddd; border: none; cursor: pointer; border-radius: 3px;">삭제</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>

</div>

</body>
</html>