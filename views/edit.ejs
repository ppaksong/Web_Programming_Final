<!-- views/edit.ejs -->
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title><%= post ? '글 수정' : (parentId ? '답글 작성' : '새 글 작성') %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 40px;
    }
    input[type="text"], textarea {
      width: 100%;
      margin-bottom: 15px;
      padding: 8px;
      font-size: 1em;
    }
    button {
      padding: 8px 16px;
      font-size: 1em;
    }
  </style>
</head>
<body>
  <h2>글 수정</h2>
  <!-- 🌟 [교정 1]: 수정 처리 POST 요청 시 404 에러 방지를 위해 /stud7 경로 주입 -->
  <form action="/stud7/board/edit/<%= post.id %>" method="post">
    <label>제목</label><br>
    <input type="text" name="title" value="<%= post.title %>" required><br><br>

    <label>내용</label><br>
    <textarea name="content" rows="8" cols="40" required><%= post.content %></textarea><br><br>

    <button type="submit">저장</button>
  </form>
  <br>
  <!-- 🌟 [교정 2]: 하위 주소창 상태에서 목록 복귀 시 경로 꼬임을 차단하기 위해 절대 고정 경로 처리 -->
  <a href="/stud7/board">← 게시판으로 돌아가기</a>
</body>
</html>