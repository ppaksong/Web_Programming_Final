    body {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 60px;
    }
    a {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 20px;
      background-color: #facc15;
      color: #000;
      text-decoration: none;
      border-radius: 5px;
    }
  </style>
</head>
<body>
  <h2><%= message %></h2>

  <!--
    🌟 [교정]: 백엔드(app.js 등)에서 `redirectUrl`을 이미 `/stud7/user/login`으로 넘겨주고 있다면 그대로 두어도 좋지만,
    만약의 경로 이탈을 방지하고 안정적인 하위 디렉터리 바인딩을 보장하기 위해 확실한 고정 경로 처리를 권장합니다.
  -->
